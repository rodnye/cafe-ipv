# ============================================
# VITE 
# ============================================

# Opcional. Usada principalmente para host en rutas relativas, como Github Pages
BASE_URL="/"

# ============================================
# ANDROID RELEASE CONFIGURATION
# ============================================

# Opcional
# ANDROID_KEYSTORE_PATH=/ruta/completa/al/keystore.jks

# Requerido para APK Releases
ANDROID_KEYSTORE_PASSWORD=tu-contraseña-keystore-aqui

# Requerido para APK Releases
ANDROID_KEY_ALIAS=tu-key-alias


# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA comitees este archivo con valores reales
# 2. Para crear un keystore nuevo:
#    keytool -genkey -v -keystore mi-keystore.jks -alias mi-alias -keyalg RSA -keysize 2048 -validity 10000
# 3. Guarda este archivo como .env (sin la extensión .example)
# 4. Añade .env a tu .gitignore